APP_ENV=production
APP_NAME=trading-bot
APP_RUNTIME=worker
DATABASE_URL=postgresql+psycopg://trading_bot:trading_bot@postgres:5432/trading_bot
DATABASE_ECHO=false
PAPER_TRADING=true
LIVE_TRADING_ENABLED=false
EXCHANGE_NAME=binance
EXCHANGE_API_BASE_URL=https://api.binance.com
EXCHANGE_REQUEST_TIMEOUT_SECONDS=10
DEFAULT_SYMBOL=BTC/USDT
DEFAULT_TIMEFRAME=1h
STRATEGY_FAST_PERIOD=20
STRATEGY_SLOW_PERIOD=50
PAPER_ACCOUNT_EQUITY=10000
RISK_PER_TRADE_PCT=0.01
MAX_OPEN_POSITIONS=1
MAX_DAILY_LOSS_PCT=0.03
WORKER_RUN_ONCE=false
WORKER_POLL_INTERVAL_SECONDS=60
MARKET_DATA_SYNC_ENABLED=false
MARKET_DATA_SYNC_LIMIT=100
MARKET_DATA_SYNC_TIMEOUT_SECONDS=10
MARKET_DATA_API_BASE_URL=https://api.binance.com
BACKTEST_SCHEDULE_ENABLED=false
BACKTEST_SCHEDULE_INTERVAL_SECONDS=3600
LIVE_RECONCILE_SCHEDULE_ENABLED=false
LIVE_RECONCILE_SCHEDULE_INTERVAL_SECONDS=300
STARTUP_STATE_SYNC_ENABLED=true
STALE_LIVE_ORDER_THRESHOLD_MINUTES=120
NOTIFICATION_CHANNEL=none
NOTIFICATION_TIMEOUT_SECONDS=5
LOG_LEVEL=INFO
